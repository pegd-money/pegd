{
  "name": "@pegd/yield-engine",
  "version": "0.1.0",
  "description": "Token-2022 interest-bearing extension wrapper and accrual math for Pegd yield stablecoins.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
